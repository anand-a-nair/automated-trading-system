# Copy to .env and fill in. .env is git-ignored — never commit real credentials.

# Zerodha Kite Connect (needed from Stage 2 onward, not for backtesting)
KITE_API_KEY=
KITE_API_SECRET=
KITE_ACCESS_TOKEN=

# Telegram alerts (Stage 3)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Trading mode: backtest | paper | live
TRADING_MODE=backtest

# Risk limits (fractions of account equity)
MAX_POSITION_PCT=0.20
MAX_DEPLOYED_PCT=0.80
MAX_DAILY_LOSS_PCT=0.02

# Storage
DATABASE_URL=sqlite:///trading.db
